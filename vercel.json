{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/client/index.html"
    }
  ],
  "headers": [
    {
      "source": "/client/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}


